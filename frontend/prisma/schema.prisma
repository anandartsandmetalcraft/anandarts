// =============================================================
// Anand Arts & Metal Craft — Database Schema
// PRD Section 8: Data Model
// =============================================================

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// AUTH — NextAuth v5 required tables
// =============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================
// USERS
// =============================================================

enum UserRole {
  CUSTOMER
  ADMIN
}

model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // e.g. phone number
  code       String
  expires    DateTime
 
  createdAt  DateTime @default(now())
 
  @@unique([identifier, code])
}
 
model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  orders    Order[]
  reviews   Review[]
}

// =============================================================
// ADDRESSES
// =============================================================

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String? // "Home", "Office", etc.
  firstName  String
  lastName   String
  phone      String
  houseNo    String
  street     String
  landmark   String?
  city       String
  state      String
  postalCode String
  country    String  @default("India")
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// =============================================================
// PRODUCTS
// =============================================================

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  material    String?
  size        String
  heightInInches Float?
  weight      String?
  hsnCode     String? // GST HSN code
  price       Int     // in paise (₹360.00 = 36000)
  compareAt   Int?    // original price for showing discount
  stock       Int     @default(0)
  reserved    Int     @default(0) // inventory lock count
  tag         String? // "Best Seller", "Limited", "New Arrival"
  couponCode  String?
  couponType  String? // "AMOUNT" or "PERCENT"
  couponValue Int?
  isActive    Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images     ProductImage[]
  orderItems OrderItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive, price])
  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// =============================================================
// ORDERS
// =============================================================

enum OrderStatus {
  CREATED
  PAYMENT_INITIATED
  PAID
  CONFIRMED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // human-readable: AA-20260405-0001
  userId          String
  addressId       String
  status          OrderStatus @default(CREATED)
  subtotal        Int         // in paise
  shippingCharge  Int         @default(0)
  discount        Int         @default(0)
  tax             Int         @default(0) // GST amount
  total           Int         // final total in paise
  notes           String?

  // Financial Engine fields
  isGiftWrapped         Boolean @default(false)
  giftWrapFee           Int @default(0) // in paise (9900 = 99 INR)
  pgFeeDeducted         Int @default(0) // in paise
  estimatedShippingCost Int @default(0) // in paise
  productCogs           Int @default(0) // in paise
  packagingBuffer       Int @default(0) // in paise
  netProfit             Int @default(0) // in paise

  // GST B2B fields (optional)
  gstNumber       String?
  companyName     String?

  // Shipping / tracking
  trackingId            String?
  trackingUrl           String?
  shippingCarrier       String?
  estimatedDelivery     DateTime?
  shiprocketOrderId     String?
  shiprocketShipmentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  address  Address    @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  payments Payment[]
  invoice  Invoice?

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String   // snapshot at time of order
  price     Int      // snapshot at time of order (paise)
  quantity  Int
  total     Int      // price * quantity

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// =============================================================
// PAYMENTS
// =============================================================

enum PaymentStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASHFREE
  PHONEPE
  UPI
  CARD
  NETBANKING
  COD
}

enum ActivityType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  ORDER_CREATED
  ORDER_PAID
  ORDER_CANCELLED
  ORDER_UPDATED
  SHIPMENT_CREATED
  SHIPPING_CREATED
  SHIPPING_UPDATED
  INVOICE_CREATED
  INVOICE_SENT
  PAYMENT_FAILED
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  amount            Int           // in paise
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod?
  
  // PhonePe specific
  merchantTransactionId String?   @unique
  phonePeTransactionId  String?
  providerReferenceId   String?
  
  // Webhook tracking
  webhookPayload    String?       @db.Text
  webhookVerified   Boolean       @default(false)
  idempotencyKey    String?       @unique // prevent duplicate processing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([merchantTransactionId])
}

model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String
  href        String?
  referenceId String?
  isRead      Boolean      @default(false)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, createdAt])
  @@index([isRead, createdAt])
  @@index([referenceId])
}

// =============================================================
// INVOICES
// =============================================================

model Invoice {
  id            String  @id @default(cuid())
  orderId       String  @unique
  invoiceNumber String  @unique // AAS001 (store) or AAW001 (website)
  channel       String  @default("WEBSITE") // "STORE" or "WEBSITE"
  pdfUrl        String?
  emailSentAt   DateTime?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// Sequential counter for invoice numbering (AAS/AAW series)
model InvoiceCounter {
  id      String @id // "STORE" or "WEBSITE"
  counter Int    @default(0)
}

// =============================================================
// REVIEWS (future-proof)
// =============================================================

model Review {
  id        String @id @default(cuid())
  userId    String
  productId String
  rating    Int    // 1-5
  title     String?
  comment   String? @db.Text
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // one review per user per product
  @@index([productId])
}

// =============================================================
// COUPONS
// =============================================================

model Coupon {
  id          String   @id @default(cuid())
  title       String
  code        String   @unique
  productType String   @default("all") // Category slug or "all"
  startDate   DateTime
  endDate     DateTime
  discount    String   // e.g. "10%" or "500"
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}
